FROM golang:1.25-alpine AS builder
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN go build -o /iss-backend .

FROM alpine:3.21
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /iss-backend /usr/local/bin/iss-backend
RUN mkdir -p /data
EXPOSE 8080
CMD ["iss-backend"]
